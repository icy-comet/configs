# the file lives in the home dir

# For ease of updating manually managed binaries like `hugo`
# Fedora already has this in PATH
# export PATH="$HOME/bin:$PATH"

# Needed if NPM's default global installation dir is changed to bypass permission restrictions
# export PATH="$HOME/.npm-global/bin:$PATH"

# To make OBS use 'Pipewire screen sharing' on Arch
# export QT_QPA_PLATFORM=wayland

# Configure default editor for some applications
# Fedora already has it set to Nano
# export EDITOR="/usr/bin/nano"

# Deta Binary Path
# export PATH="$HOME/.deta/bin:$PATH"
