# Needed if NPM's default global installation dir is changed to bypass permission restrictions
# export PATH="$HOME/.npm-global/bin:$PATH"

# Deta Binary Path
# export PATH="$HOME/.deta/bin:$PATH"

# ANSI Color Codes based on `termcap`
# `termcap` is deprecated in many distributions. see `man termcap`
# but `less` continues to use it
export LESS_TERMCAP_mb=$'\e[1;32m'
export LESS_TERMCAP_md=$'\e[1;32m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_so=$'\e[01;33m'
export LESS_TERMCAP_ue=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;4;31m'
