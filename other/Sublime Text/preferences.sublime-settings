{
	"color_scheme": "GitHub Dimmed.sublime-color-scheme",
	"theme": "GitHub Dimmed.sublime-theme",
	"font_face": "Cascadia Code",
	"font_options": ["dlig"],
	"font_size": 12,
	"line_padding_bottom": 3,
    "line_padding_top": 3,
	"caret_style": "smooth",
    "caret_extra_bottom": 5,
    "caret_extra_top": 5,
	"hot_exit": "disabled",
	"remember_workspace": false,
	// github theme's suggested settings
	"highlight_line": true,
	"margin": 20
}
