{
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false, // needed with Redhat YAML extension
  "editor.fontSize": 16,
  "editor.fontFamily": "\"Cascadia Code\",\"Operator Mono Lig\",\"Dank Mono\", monospace",
  "editor.lineHeight": 1.6,
  "editor.mouseWheelZoom": true, // zoom with Ctrl+MouseWheel
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": true, // in-built bracket colorization
  "editor.fontLigatures": true,
  "editor.wordWrap": "on",
  "terminal.integrated.fontFamily": "\"CaskaydiaCove NF\"",
  "emmet.includeLanguages": {
    "nunjucks": "html"
  },
  "explorer.confirmDelete": false,
  "files.exclude": {
    "node_modules": true,
    ".vscode": true,
    "venv": true
  },
  "files.trimTrailingWhitespace": true,
  "workbench.iconTheme": "moxer-icons",
  "workbench.colorTheme": "Bearded Theme Surprising Blueberry",
  "workbench.productIconTheme": "icons-carbon",
  "window.menuBarVisibility": "compact",
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }

  // Project-wise changes
  // "editor.formatOnSave": false,

  // Linux-Specific Settings
  // "window.titleBarStyle": "custom", // to not use the OS native window

  // Tailwind-Specific Settings
  /* "css.validate": false,
  "editor.quickSuggestions": {
    "strings": true
  },
  "tailwindCSS.emmetCompletions": true, */
}
